# OwoDesk Business — serveur dédié client
# cp env.business.example .env

DEPLOYMENT_MODE=dedicated
DJANGO_SETTINGS_MODULE=config.settings.production

# Version des images GHCR (alignée livraison Code Lab)
OWODESK_IMAGE_TAG=1.0.0
# Propriétaires GHCR (backend = compte codelabbj, frontend = org codelab-bj)
GHCR_BUSINESS_ORG=codelabbj
GHCR_FRONTEND_ORG=codelab-bj

# Identité instance (kit e-mail OwoDesk)
INSTANCE_ID=
DEDICATED_HEARTBEAT_SECRET=
LICENSE_SERVER_URL=https://api.erp.codelab.bj
LICENSE_FILE_PATH=.license

# Django
ALLOWED_HOSTS=*
SECRET_KEY=change-me-long-random

# Base de données
DB_NAME=owodesk
DB_USER=owodesk
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

# URLs publiques — le navigateur passe par le frontend (:8080)
FRONTEND_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8080
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Images (générées à partir du tag ; ne pas éditer sauf cas particulier)
GHCR_BUSINESS_IMAGE=ghcr.io/codelabbj/owodesk-business:1.0.0
GHCR_FRONTEND_IMAGE=ghcr.io/codelab-bj/owodesk-frontend:1.0.0
GHCR_PULL_TOKEN=

# BYOK
# GROQ_API_KEY=
# EMAIL_HOST=
